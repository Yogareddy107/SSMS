{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["USER", "ADMIN", "PROVIDER"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "Available service for booking",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "averageRating": { "type": "number" },
        "reviewCount": { "type": "number" }
      },
      "required": ["name", "price"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Service booking record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "providerId": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "ACCEPTED", "IN_PROGRESS", "COMPLETED", "CANCELLED"] },
        "date": { "type": "string", "format": "date" },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "subTasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["userId", "serviceId", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "User review for a service/provider",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "bookingId": { "type": "string" },
        "serviceId": { "type": "string" },
        "providerId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "bookingId", "rating"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Available services"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Service bookings"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Service reviews"
    }
  }
}
